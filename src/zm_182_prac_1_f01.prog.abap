*----------------------------------------------------------------------*
***INCLUDE ZM_182_PRAC_1_F01.
*----------------------------------------------------------------------*
*&---------------------------------------------------------------------*
*& Form GET_DATA
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM get_data .
  SELECT *
  FROM mara
  INTO TABLE gt_mara
  WHERE mtart = p_mtart AND matnr IN s_matnr.
ENDFORM.
*&---------------------------------------------------------------------*
*& Form WRITE_DATA
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM write_data .
  cl_demo_output=>display_data( gt_mara ).
ENDFORM.
